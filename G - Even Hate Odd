t = int(input())

for j in range(t):
    n = int(input())
    a = list(map(int, input().split()))

    if n % 2 != 0:
        print(-1)
        continue

    even = 0
    odd = 0

    for i in a:
        if i % 2 == 0:
            even += 1
        else:
            odd += 1

    print(abs(even - odd) // 2)