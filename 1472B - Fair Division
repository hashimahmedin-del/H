t = int(input())

for _ in range(t):
    n = int(input())
    a = list(map(int, input().split()))

    total = sum(a)
    count1 = a.count(1)
    count2 = a.count(2)

    if total % 2 != 0:
        print("NO")

    elif count1 == 0 and count2 % 2 != 0:
        print("NO")

    else:
        print("YES")